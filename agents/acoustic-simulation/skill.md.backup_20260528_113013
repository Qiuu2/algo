        confidence_level: 0.95
      - type: "waterfall_plot"
        time_window: "T20"
  
  expected_delivery:
    processed_curves: "processed_fr.csv"
    di_values: "di_results.json"
    statistical_report: "stat_report.md"
    plots: ["smoothed_fr.png", "waterfall.png"]

